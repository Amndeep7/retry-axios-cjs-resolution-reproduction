{
  "compilerOptions": {
    "lib": ["esnext"],
    "target": "esnext",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,

    "module": "nodenext",
    "moduleResolution": "nodenext",
    "rootDir": ".",

    "strict": true,
    "noImplicitAny": true,

    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "inlineSources": true,
    "outDir": "lib",

    "incremental": true,

    "resolveJsonModule": true,
    "esModuleInterop": true,

    "skipLibCheck": true
  },
  "include": ["**/*.ts"],
  "exclude": ["node_modules", "lib"]
}

